    },
    "optional_for_occupation": {
      "edgeType": "optional_for_occupation",
      "sourceClasses": ["skill_like"],
      "targetClasses": ["role_like"]
    },
    "occupation_benefits_from_optional_skill": {
      "edgeType": "occupation_benefits_from_optional_skill",
      "sourceClasses": ["role_like"],
      "targetClasses": ["skill_like"]
    },
    "transferable_to": {
      "edgeType": "transferable_to",
      "sourceClasses": ["skill_like"],
      "targetClasses": ["skill_like", "abstraction", "process_like"]
    }
  },
  "illegalRetypings": [
    {
      "from": "example",
      "to": "skill",
      "reason": "Examples are learner-facing instances; promote the underlying concept first instead of retyping the instance as a skill."
    },
    {
      "from": "example",
      "to": "concept",
      "reason": "Examples should remain instances. Create or merge into the concept they illustrate rather than retyping them into abstractions."
    },
    {
      "from": "counterexample",
      "to": "concept",
      "reason": "Counterexamples are diagnostic instances, not abstractions."
    },
    {
      "from": "counterexample",
      "to": "skill",
      "reason": "Counterexamples cannot be promoted into skills without losing their diagnostic role."
    },
    {
      "from": "misconception",
      "to": "concept",
      "reason": "Misconceptions must stay explicitly represented; resolve them through links or merges, not by erasing them via retyping."
    },
    {
      "from": "occupation",
      "to": "concept",
      "reason": "Occupations are role-like entities and cannot be silently collapsed into concept-bearing abstractions."
    },
    {
      "from": "concept",
      "to": "occupation",
      "reason": "Concepts and occupations belong to different ontology branches and require explicit canonical replacement instead of direct retyping."
    }
  ]
}
