// Prisma schema for knowledge-graph-service
// Database: PostgreSQL
// Design: Workflow data for CKG mutation pipeline, structural metrics,
//         misconception patterns, and aggregation evidence.
// Graph data (PKG/CKG nodes, edges, traversals) lives in Neo4j.

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ============================================================================
// CKG Mutation — Formally guarded canonical graph mutation pipeline
// ============================================================================
// Every CKG mutation follows the typestate protocol:
//   Proposed → Validating → Validated → Proving → Proven → Committing → Committed
//   Any state can transition to Rejected.
// Mutations are expressed in a constrained DSL — no direct raw writes.

model CkgMutation {
    id     String @id @db.VarChar(50)
    userId String @map("user_id") @db.VarChar(50)

    // Typestate — current position in the mutation pipeline
    state CkgMutationState @default(PROPOSED)

    // Mutation type discriminator
    mutationType String @map("mutation_type") @db.VarChar(100)

    // DSL operation payload — the mutation expressed in the constrained DSL
    operation Json

    // Validation results accumulated during the pipeline
    validationResult Json? @map("validation_result")

    // Evidence references — links to aggregation evidence or external sources
    evidenceRefs Json? @map("evidence_refs")

    // Target graph location context (CKG node/edge IDs affected)
    targetNodeIds String[] @default([]) @map("target_node_ids")
    targetEdgeIds String[] @default([]) @map("target_edge_ids")

    // Processing results from each pipeline stage
    proofResult     Json?   @map("proof_result")
    commitResult    Json?   @map("commit_result")
    rejectionReason String? @map("rejection_reason") @db.VarChar(2000)

    // Priority for processing queue
    priority Int @default(0)

    // Proposer's rationale for the mutation
    rationale String? @db.VarChar(2000)

    // Denormalized evidence count for promotion band lookup
    evidenceCount Int @default(0) @map("evidence_count")

    // Number of recovery attempts for stuck mutations (max retry enforcement)
    recoveryAttempts Int @default(0) @map("recovery_attempts")

    // Number of revision cycles this mutation has been through
    revisionCount Int @default(0) @map("revision_count")

    // Latest reviewer feedback requesting changes (null if no active revision)
    revisionFeedback String? @map("revision_feedback") @db.VarChar(4000)

    // Extensible metadata
    metadata Json @default("{}")

    // Optimistic locking
    version Int @default(1)

    // Audit fields
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")
    createdBy String?  @map("created_by") @db.VarChar(50)
    updatedBy String?  @map("updated_by") @db.VarChar(50)

    // Relations
    auditLog            CkgMutationAuditLog[]
    aggregationEvidence AggregationEvidence[]

    // Indexes
    @@index([state])
    @@index([userId])
    @@index([mutationType])
    @@index([priority])
    @@index([createdAt])
    @@index([state, priority])
    @@index([userId, state])
    @@index([userId, createdAt])
    @@map("ckg_mutations")
}

// ============================================================================
// CKG Mutation Audit Log — Immutable append-only state transition log
// ============================================================================
// Every state transition in the mutation pipeline is recorded here.
// This table is append-only — no updates or deletes permitted.

model CkgMutationAuditLog {
    id         String @id @db.VarChar(50)
    mutationId String @map("mutation_id") @db.VarChar(50)

    // State transition
    fromState CkgMutationState @map("from_state")
    toState   CkgMutationState @map("to_state")

    // Who/what triggered the transition
    triggeredBy String  @map("triggered_by") @db.VarChar(100)
    reason      String? @db.VarChar(2000)

    // Snapshot of relevant data at transition time
    snapshot Json? @default("{}")

    // Correlation for distributed tracing
    correlationId String? @map("correlation_id") @db.VarChar(100)

    // Audit — no updatedAt because this table is append-only
    createdAt DateTime @default(now()) @map("created_at")

    // Relations
    mutation CkgMutation @relation(fields: [mutationId], references: [id], onDelete: Cascade)

    // Indexes
    @@index([mutationId])
    @@index([mutationId, createdAt])
    @@index([fromState, toState])
    @@index([triggeredBy])
    @@index([correlationId])
    @@index([createdAt])
    @@map("ckg_mutation_audit_log")
}

// ============================================================================
// Structural Metric Snapshot — Periodic per-user structural metric cache
// ============================================================================
// Snapshots of computed structural metrics (AD, DCG, SLI, SCE, ULS, TBS, SDF,
// SSE, SAA, SSG, BSI) stored periodically for longitudinal tracking and agent
// reasoning.
// Actual computation happens in Neo4j; these are cached results.

model StructuralMetricSnapshot {
    id     String @id @db.VarChar(50)
    userId String @map("user_id") @db.VarChar(50)

    // Optional scope: metrics can be global or domain-specific
    domain String? @db.VarChar(200)

    // Study mode lens these metrics were computed under
    studyMode StudyMode @default(KNOWLEDGE_GAINING) @map("study_mode")

    // The computed metrics as a JSON object
    // Structure: { AD, DCG, SLI, SCE, ULS, TBS, SDF, SSE, SAA, SSG, BSI }
    metrics Json

    // Schema version for forward-compatible deserialization of metrics.
    // Older snapshots missing new metric fields can be detected by checking this.
    schemaVersion Int @default(1) @map("schema_version")

    // Optional graph region identifier (for per-region staging)
    graphRegion String? @map("graph_region") @db.VarChar(200)

    // Metacognitive stage at snapshot time (STAGE_1..STAGE_4)
    metacognitiveStage Int? @map("metacognitive_stage")

    // Number of PKG nodes at snapshot time (for context)
    nodeCount Int? @map("node_count")

    // Audit fields
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Indexes
    @@index([userId])
    @@index([userId, domain])
    @@index([userId, domain, studyMode])
    @@index([userId, createdAt])
    @@index([domain])
    @@index([studyMode])
    @@index([createdAt])
    @@index([metacognitiveStage])
    @@map("structural_metric_snapshots")
}

// ============================================================================
// Graph Snapshot — Recoverable graph-state capture for PKG/CKG restore
// ============================================================================

model GraphSnapshot {
    id String @id @db.VarChar(50)

    graphType String @map("graph_type") @db.VarChar(20)
    scopeUserId String? @map("scope_user_id") @db.VarChar(50)
    scopeDomain String? @map("scope_domain") @db.VarChar(200)

    nodeCount Int @default(0) @map("node_count")
    edgeCount Int @default(0) @map("edge_count")
    schemaVersion Int @default(1) @map("schema_version")

    snapshotData Json @map("snapshot_data")

    reason String? @db.VarChar(2000)
    sourceCursor String? @map("source_cursor") @db.VarChar(100)

    createdAt DateTime @default(now()) @map("created_at")
    createdBy String? @map("created_by") @db.VarChar(50)

    @@index([graphType, createdAt])
    @@index([scopeUserId, createdAt])
    @@index([scopeDomain, createdAt])
    @@index([graphType, scopeUserId, scopeDomain, createdAt])
    @@map("graph_snapshots")
}

model GraphCrdtStat {
    id String @id @db.VarChar(50)

    statKey String @unique @map("stat_key") @db.VarChar(500)
    graphType String @map("graph_type") @db.VarChar(20)
    targetKind String @map("target_kind") @db.VarChar(50)
    targetNodeId String? @map("target_node_id") @db.VarChar(200)
    proposedLabel String? @map("proposed_label") @db.VarChar(500)
    evidenceType String @map("evidence_type") @db.VarChar(100)

    supportCounter Json @map("support_counter")
    opposeCounter Json @map("oppose_counter")
    neutralCounter Json @map("neutral_counter")
    confidenceCounter Json @map("confidence_counter")

    metadata Json @default("{}")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    appliedSignals GraphCrdtAppliedSignal[]

    @@index([graphType, targetKind])
    @@index([targetNodeId])
    @@index([proposedLabel])
    @@index([evidenceType])
    @@map("graph_crdt_stats")
}

model GraphCrdtAppliedSignal {
    id String @id @db.VarChar(50)

    statKey String @map("stat_key") @db.VarChar(500)
    evidenceId String @unique @map("evidence_id") @db.VarChar(50)
    replicaId String @map("replica_id") @db.VarChar(100)

    createdAt DateTime @default(now()) @map("created_at")

    stat GraphCrdtStat @relation(fields: [statKey], references: [statKey], onDelete: Cascade)

    @@index([statKey])
    @@index([replicaId])
    @@map("graph_crdt_applied_signals")
}

// ============================================================================
// Aggregation Evidence — PKG → CKG aggregation pipeline records
// ============================================================================
// Records which PKG signals contributed to which CKG mutation proposals.
// This provides auditability for the crowdsourced aggregation process.

model AggregationEvidence {
    id         String  @id @db.VarChar(50)
    mutationId String? @map("mutation_id") @db.VarChar(50)

    // Source PKG information
    sourceUserId    String @map("source_user_id") @db.VarChar(50)
    sourcePkgNodeId String @map("source_pkg_node_id") @db.VarChar(200)

    // CKG target — the canonical node this evidence supports (null before linkage)
    ckgTargetNodeId String? @map("ckg_target_node_id") @db.VarChar(200)

    // Label proposed by the PKG observation
    proposedLabel String? @map("proposed_label") @db.VarChar(500)

    // Type of evidence (e.g., "edge_agreement", "misconception_signal", "confidence_data")
    evidenceType String @map("evidence_type") @db.VarChar(100)

    // Evidence payload — the actual signal data
    payload Json

    // Confidence score of this evidence (branded ConfidenceScore at domain layer)
    confidence Float @default(0.0)

    // Strength/weight of this evidence in the aggregation
    weight Float @default(1.0)

    // Whether this evidence supported or opposed the mutation
    direction String @default("support") @db.VarChar(20) // support, oppose, neutral

    // Audit fields
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Relations (optional — evidence can exist before mutation is proposed)
    mutation CkgMutation? @relation(fields: [mutationId], references: [id], onDelete: Cascade)

    // Indexes
    @@index([mutationId])
    @@index([sourceUserId])
    @@index([evidenceType])
    @@index([mutationId, sourceUserId])
    @@index([ckgTargetNodeId])
    @@index([ckgTargetNodeId, sourceUserId])
    @@index([createdAt])
    @@map("aggregation_evidence")
}

// ============================================================================
// Misconception Pattern — Executable pattern definitions
// ============================================================================
// Defines patterns that detect misconceptions in PKGs. These are the
// executable specifications used by the diagnostic agent and reasoning layers.

model MisconceptionPattern {
    id String @id @db.VarChar(50)

    // Human-readable identification
    name        String  @db.VarChar(200)
    description String? @db.VarChar(2000)

    // Which misconception type this pattern detects (maps to MisconceptionType enum)
    misconceptionType String @map("misconception_type") @db.VarChar(100)

    // Pattern kind discriminator
    patternKind String @map("pattern_kind") @db.VarChar(100)

    // Pattern specification — the executable pattern definition
    // Structure depends on patternKind (graph pattern, statistical, heuristic)
    spec Json

    // Scoring model configuration (reserved for future per-pattern scoring
    // customization; not yet surfaced in domain IMisconceptionPattern)
    scoringModel Json @default("{}") @map("scoring_model")

    // Domain scope — which knowledge domains this pattern applies to
    // (reserved for future domain-scoped detection; not yet in domain model)
    domains String[] @default([])

    // Severity level (how critical is this misconception type)
    severity MisconceptionSeverity @default(MODERATE)

    // Minimum confidence to trigger detection (per-pattern configurable)
    threshold Float @default(0.5)

    // Whether this pattern is currently active
    active Boolean @default(true)

    // Extensible metadata
    metadata Json @default("{}")

    // Audit fields
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")
    createdBy String?  @map("created_by") @db.VarChar(50)
    updatedBy String?  @map("updated_by") @db.VarChar(50)

    // Relations
    interventions InterventionTemplate[]
    detections    MisconceptionDetection[]

    // Indexes
    @@index([misconceptionType])
    @@index([patternKind])
    @@index([active])
    @@index([severity])
    @@index([domains], type: Gin)
    @@index([createdAt])
    @@map("misconception_patterns")
}

// ============================================================================
// Intervention Template — Remediation templates linked to misconceptions
// ============================================================================
// Defines intervention/remediation strategies that can be applied when a
// misconception pattern matches. Used by strategy and content generation agents.

model InterventionTemplate {
    id String @id @db.VarChar(50)

    // Link to the misconception this intervention addresses
    misconceptionPatternId String @map("misconception_pattern_id") @db.VarChar(50)

    // Human-readable identification
    name        String  @db.VarChar(200)
    description String? @db.VarChar(2000)

    // Intervention type (e.g., "contrastive_pair", "boundary_case", "retrieval_cue")
    interventionType String @map("intervention_type") @db.VarChar(100)

    // Template specification — how to generate the intervention
    spec Json

    // Priority relative to other interventions for the same misconception
    priority Int @default(0)

    // Effectiveness tracking (reserved for future A/B testing of interventions;
    // not yet surfaced in the domain model — written by background analytics job)
    useCount    Int   @default(0) @map("use_count")
    successRate Float @default(0.0) @map("success_rate")

    // Whether this template is currently active
    active Boolean @default(true)

    // Extensible metadata
    metadata Json @default("{}")

    // Audit fields
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")
    createdBy String?  @map("created_by") @db.VarChar(50)
    updatedBy String?  @map("updated_by") @db.VarChar(50)

    // Relations
    misconceptionPattern MisconceptionPattern @relation(fields: [misconceptionPatternId], references: [id], onDelete: Cascade)

    // Indexes
    @@index([misconceptionPatternId])
    @@index([interventionType])
    @@index([active])
    @@index([priority])
    @@index([createdAt])
    @@map("intervention_templates")
}

// ============================================================================
// Misconception Detection — Runtime detection instances
// ============================================================================
// Records actual misconception detections for a user. Created when patterns
// match against a user's PKG. Tracks the detection → resolution lifecycle.
// Read by Strategy Agent (adjust strategy), Diagnostic Agent (pattern analysis).

model MisconceptionDetection {
    id                     String @id @db.VarChar(50)
    userId                 String @map("user_id") @db.VarChar(50)
    misconceptionPatternId String @map("misconception_pattern_id") @db.VarChar(50)

    // Study mode lens in which this misconception was detected
    studyMode StudyMode @default(KNOWLEDGE_GAINING) @map("study_mode")

    // Which misconception type was detected (denormalized from pattern for querying)
    misconceptionType String @map("misconception_type") @db.VarChar(100)

    // Graph nodes affected by this misconception
    affectedNodeIds String[] @default([]) @map("affected_node_ids")

    // Detection confidence (branded ConfidenceScore at domain layer)
    confidence Float @default(0.0)

    // Per-detection severity (defaults from pattern but can be overridden)
    severity MisconceptionSeverity @default(MODERATE)

    // Normalised severity score (0.0–1.0) for ranking and triage
    severityScore Float @default(0.5) @map("severity_score")

    // Family key (e.g. 'graph-structural') — resolved from config
    family String @default("uncategorized") @db.VarChar(100)

    // Human-readable description of this detection instance
    description String? @db.VarChar(2000)

    // How many times this misconception has been detected (upsert counter)
    detectionCount Int @default(1) @map("detection_count")

    // Status lifecycle: detected → confirmed → addressed → resolved → recurring
    status String @default("detected") @map("status") @db.VarChar(50)

    // Extensible metadata (evidence details, agent reasoning, etc.)
    metadata Json @default("{}")

    // Lifecycle timestamps
    detectedAt      DateTime  @default(now()) @map("detected_at")
    lastDetectedAt  DateTime  @default(now()) @map("last_detected_at")
    resolvedAt      DateTime? @map("resolved_at")

    // Relations
    pattern MisconceptionPattern @relation(fields: [misconceptionPatternId], references: [id])

    // Composite unique for upsert dedup (one active detection per user+pattern)
    @@unique([userId, misconceptionPatternId, studyMode, status], name: "uq_user_pattern_mode_status")

    // Indexes
    @@index([userId])
    @@index([userId, status])
    @@index([userId, studyMode])
    @@index([misconceptionType])
    @@index([misconceptionPatternId])
    @@index([status])
    @@index([studyMode])
    @@index([severity])
    @@index([family])
    @@index([affectedNodeIds], type: Gin)
    @@index([detectedAt])
    @@index([lastDetectedAt])
    @@map("misconception_detections")
}

// ============================================================================
// PKG Operation Log — Append-only per-user PKG mutation changelog
// ============================================================================
// Records every PKG write operation for undo/redo, aggregation pipeline input,
// and offline sync reconciliation. This table is append-only — no updates or
// deletes permitted (soft-deletes on the operations themselves are separate
// log entries). Each user has a monotonically increasing sequence number.

model PkgOperationLog {
    id     String @id @db.VarChar(50)
    userId String @map("user_id") @db.VarChar(50)

    // Monotonically increasing per-user sequence for ordering guarantees
    // Used by offline sync reconciliation to detect gaps
    sequenceNumber Int @map("sequence_number")

    // Operation type discriminator (matches PkgOperationType enum in domain layer)
    operationType String @map("operation_type") @db.VarChar(50)

    // The full operation payload as a JSON discriminated union
    // Structure depends on operationType (node_created, edge_deleted, etc.)
    operation Json

    // Affected entity IDs for indexed lookups
    affectedNodeIds String[] @default([]) @map("affected_node_ids")
    affectedEdgeIds String[] @default([]) @map("affected_edge_ids")

    // Correlation for distributed tracing
    correlationId String? @map("correlation_id") @db.VarChar(100)

    // Audit — no updatedAt because this table is append-only
    createdAt DateTime @default(now()) @map("created_at")

    // Indexes
    @@unique([userId, sequenceNumber])
    @@index([userId])
    @@index([userId, createdAt])
    @@index([userId, operationType])
    @@index([operationType])
    @@index([affectedNodeIds], type: Gin)
    @@index([affectedEdgeIds], type: Gin)
    @@index([createdAt])
    @@index([correlationId])
    @@map("pkg_operation_log")
}

// ============================================================================
// Metrics Staleness — Tracks when user+domain metrics need recomputation
// ============================================================================
// Upserted on every PKG mutation (node/edge CRUD). Phase 7's computeMetrics
// checks lastStructuralChangeAt against the latest StructuralMetricSnapshot
// to determine if recomputation is needed.

model MetricsStaleness {
    id     String @id @db.VarChar(50)
    userId String @map("user_id") @db.VarChar(50)

    // Knowledge domain the staleness applies to
    domain String @db.VarChar(200)

    // Study mode lens
    studyMode StudyMode @default(KNOWLEDGE_GAINING) @map("study_mode")

    // When the last structural change occurred (PKG node/edge mutation)
    lastStructuralChangeAt DateTime @map("last_structural_change_at")

    // What type of mutation triggered staleness (for diagnostics)
    lastMutationType String @map("last_mutation_type") @db.VarChar(50)

    // Audit fields
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Constraints — one staleness record per user+domain
    @@unique([userId, domain, studyMode])
    @@index([userId])
    @@index([userId, domain])
    @@index([userId, domain, studyMode])
    @@index([studyMode])
    @@index([lastStructuralChangeAt])
    @@map("metrics_staleness")
}

// ============================================================================
// Ontology Imports — Source registry, run orchestration, and staging metadata
// ============================================================================

model OntologyImportSource {
    id String @id @db.VarChar(50)

    name        String @db.VarChar(200)
    role        String @db.VarChar(50)
    accessMode  String @map("access_mode") @db.VarChar(50)
    description String @db.VarChar(2000)

    homepageUrl      String? @map("homepage_url") @db.VarChar(500)
    documentationUrl String? @map("documentation_url") @db.VarChar(500)

    supportedLanguages String[] @default([]) @map("supported_languages")
    supportsIncremental Boolean  @default(false) @map("supports_incremental")
    enabled             Boolean  @default(true)

    latestReleaseVersion     String?   @map("latest_release_version") @db.VarChar(200)
    latestReleasePublishedAt DateTime? @map("latest_release_published_at")
    latestReleaseChecksum    String?   @map("latest_release_checksum") @db.VarChar(200)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    runs OntologyImportRun[]

    @@index([role])
    @@index([accessMode])
    @@index([enabled])
    @@map("ontology_import_sources")
}

model OntologyImportRun {
    id String @id @db.VarChar(50)

    sourceId String @map("source_id") @db.VarChar(50)

    sourceVersion String? @map("source_version") @db.VarChar(200)
    configuration Json    @default("{}")
    submittedMutationIds Json @default("[]") @map("submitted_mutation_ids")
    status              String  @db.VarChar(50)
    trigger             String  @db.VarChar(50)
    initiatedBy         String? @map("initiated_by") @db.VarChar(100)

    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime  @updatedAt @map("updated_at")
    startedAt   DateTime? @map("started_at")
    completedAt DateTime? @map("completed_at")

    failureReason String? @map("failure_reason") @db.VarChar(2000)

    source      OntologyImportSource       @relation(fields: [sourceId], references: [id], onDelete: Restrict)
    artifacts   OntologyImportArtifact[]
    checkpoints OntologyImportCheckpoint[]
    parsedBatch OntologyParsedBatch?

    @@index([sourceId])
    @@index([status])
    @@index([trigger])
    @@index([createdAt])
    @@index([sourceId, status])
    @@map("ontology_import_runs")
}

model OntologyImportArtifact {
    id String @id @db.VarChar(50)

    runId    String @map("run_id") @db.VarChar(50)
    sourceId String @map("source_id") @db.VarChar(50)

    kind        String  @db.VarChar(50)
    storageKey  String  @map("storage_key") @db.VarChar(500)
    contentType String? @map("content_type") @db.VarChar(200)
    checksum    String? @db.VarChar(200)
    sizeBytes   Int?    @map("size_bytes")

    createdAt DateTime @default(now()) @map("created_at")

    run OntologyImportRun @relation(fields: [runId], references: [id], onDelete: Cascade)

    @@index([runId])
    @@index([sourceId])
    @@index([kind])
    @@map("ontology_import_artifacts")
}

model OntologyImportCheckpoint {
    id String @id @db.VarChar(50)

    runId String @map("run_id") @db.VarChar(50)

    step   String @db.VarChar(50)
    status String @db.VarChar(50)

    startedAt   DateTime? @map("started_at")
    completedAt DateTime? @map("completed_at")
    detail      String?   @db.VarChar(2000)

    run OntologyImportRun @relation(fields: [runId], references: [id], onDelete: Cascade)

    @@index([runId])
    @@index([step])
    @@index([status])
    @@map("ontology_import_checkpoints")
}

model OntologyParsedBatch {
    runId String @id @map("run_id") @db.VarChar(50)

    sourceId      String  @map("source_id") @db.VarChar(50)
    sourceVersion String? @map("source_version") @db.VarChar(200)
    recordCount   Int     @map("record_count")
    artifactId    String  @map("artifact_id") @db.VarChar(50)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    run OntologyImportRun @relation(fields: [runId], references: [id], onDelete: Cascade)

    @@index([sourceId])
    @@map("ontology_parsed_batches")
}

// ============================================================================
// Enums
// ============================================================================

enum CkgMutationState {
    PROPOSED
    VALIDATING
    VALIDATED
    PROVING
    PROVEN
    COMMITTING
    COMMITTED
    REJECTED
    PENDING_REVIEW
    REVISION_REQUESTED

    @@map("ckg_mutation_state")
}

enum MisconceptionSeverity {
    LOW
    MODERATE
    HIGH
    CRITICAL

    @@map("misconception_severity")
}

enum StudyMode {
    LANGUAGE_LEARNING
    KNOWLEDGE_GAINING

    @@map("study_mode")
}
