# ==============================================================================
# Noema Knowledge Graph Service - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values

# ------------------------------------------------------------------------------
# Service Configuration
# ------------------------------------------------------------------------------
SERVICE_NAME=knowledge-graph-service
SERVICE_VERSION=0.1.0
NODE_ENV=development

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=3006
BODY_LIMIT=1048576
BATCH_BODY_LIMIT=5242880

# ------------------------------------------------------------------------------
# Database Configuration (PostgreSQL via Prisma)
# ------------------------------------------------------------------------------
# Workflow data: CKG mutations, structural metrics, misconception patterns
DATABASE_URL=postgresql://noema:noema_dev_password@localhost:5432/noema_knowledge_graph?schema=public

# ------------------------------------------------------------------------------
# Neo4j Configuration (Graph Database)
# ------------------------------------------------------------------------------
# Primary store for PKG/CKG nodes, edges, traversals
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=noema_neo4j_dev
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=100
NEO4J_ACQUISITION_TIMEOUT_MS=60000

# ------------------------------------------------------------------------------
# Redis Configuration
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_EVENT_STREAM=noema:events:knowledge-graph-service
REDIS_STREAM_MAX_LEN=10000

# ------------------------------------------------------------------------------
# JWT Configuration (verification only - tokens issued by user-service)
# ------------------------------------------------------------------------------
# Must match user-service's ACCESS_TOKEN_SECRET
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-min-32-chars
JWT_ISSUER=noema.app
JWT_AUDIENCE=noema.app

# ------------------------------------------------------------------------------
# Cache Configuration
# ------------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_PREFIX=kgs

# ------------------------------------------------------------------------------
# Ontology Import Defaults
# ------------------------------------------------------------------------------
YAGO_VARIANT=full

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_WRITE_MAX=30
RATE_LIMIT_BATCH_MAX=10

# ------------------------------------------------------------------------------
# CORS Configuration (disabled by default — the API gateway handles CORS)
# Set CORS_ENABLED=true only when running without the gateway.
# ------------------------------------------------------------------------------
# CORS_ENABLED=false
# CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3100,http://localhost:3005,http://localhost:3006,http://localhost:3007,http://localhost:3008,http://localhost:3009,http://localhost:3010,http://localhost:3011,http://localhost:3012,http://localhost:3013,http://localhost:3014,http://localhost:3015
# CORS_CREDENTIALS=true

# ------------------------------------------------------------------------------
# Event Consumers
# ------------------------------------------------------------------------------
EVENT_CONSUMERS_ENABLED=true
CONSUMER_NAME=knowledge-graph-service
EVENT_STREAM_CONTENT=noema:events:content-service
EVENT_STREAM_SESSION=noema:events:session-service
EVENT_STREAM_USER=noema:events:user-service

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_PRETTY=true
