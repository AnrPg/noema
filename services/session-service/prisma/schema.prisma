// Prisma schema for session-service
// Database: PostgreSQL

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ============================================================================
// Session Entity — FSM-based learning session
// ============================================================================

model Session {
    id     String @id @db.VarChar(50)
    userId String @map("user_id") @db.VarChar(50)

    // DeckQuery reference (resolved by Learning Agent before session start)
    deckQueryId String @map("deck_query_id") @db.VarChar(50)

    // FSM state
    state SessionState @default(ACTIVE)

    // Learning configuration
    learningMode        LearningMode
    studyMode           StudyMode    @default(KNOWLEDGE_GAINING) @map("study_mode")
    teachingApproach    String       @map("teaching_approach") @db.VarChar(100)
    schedulingAlgorithm String       @map("scheduling_algorithm") @db.VarChar(50)

    // Strategy (mutable mid-session)
    loadoutId        String? @map("loadout_id") @db.VarChar(50)
    loadoutArchetype String? @map("loadout_archetype") @db.VarChar(50)
    forceLevel       String? @map("force_level") @db.VarChar(20)

    // Session configuration (immutable after creation)
    config Json @default("{}")

    // Running statistics (updated on each attempt)
    stats Json @default("{}")

    // Queue metadata
    initialQueueSize Int @default(0) @map("initial_queue_size")

    // Pause tracking
    pauseCount            Int       @default(0) @map("pause_count")
    totalPausedDurationMs Int       @default(0) @map("total_paused_duration_ms")
    lastPausedAt          DateTime? @map("last_paused_at")

    // Lifecycle timestamps
    startedAt      DateTime  @default(now()) @map("started_at")
    lastActivityAt DateTime  @default(now()) @map("last_activity_at")
    completedAt    DateTime? @map("completed_at")

    // Termination
    terminationReason String? @map("termination_reason") @db.VarChar(50)

    // Audit fields
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Optimistic locking
    version Int @default(1)

    // Relations
    attempts   Attempt[]
    queueItems SessionQueueItem[]
    cohortHandshakes SessionCohortHandshake[]

    // Indexes
    @@index([userId])
    @@index([userId, studyMode])
    @@index([userId, state])
    @@index([state])
    @@index([startedAt])
    @@index([lastActivityAt])
    @@index([userId, completedAt])
    @@map("sessions")
}

// ============================================================================
// Attempt Entity — Single card review attempt
// ============================================================================

model Attempt {
    id        String @id @db.VarChar(50)
    sessionId String @map("session_id") @db.VarChar(50)
    cardId    String @map("card_id") @db.VarChar(50)
    userId    String @map("user_id") @db.VarChar(50)

    // Ordering within session
    sequenceNumber Int @map("sequence_number")

    // Response
    outcome     AttemptOutcome
    rating      Rating
    ratingValue Int            @map("rating_value") @db.SmallInt

    // Timing
    responseTimeMs           Float  @map("response_time_ms")
    dwellTimeMs              Float  @map("dwell_time_ms")
    timeToFirstInteractionMs Float? @map("time_to_first_interaction_ms")

    // Metacognitive signals
    confidenceBefore       Float?    @map("confidence_before")
    confidenceAfter        Float?    @map("confidence_after")
    calibrationDelta       Float?    @map("calibration_delta")
    wasRevisedBeforeCommit Boolean   @default(false) @map("was_revised_before_commit")
    revisionCount          Int       @default(0) @map("revision_count")
    hintRequestCount       Int       @default(0) @map("hint_request_count")
    hintDepthReached       HintDepth @map("hint_depth_reached")

    // Context at time of attempt (denormalized snapshot)
    contextSnapshot Json @map("context_snapshot")

    // Prior scheduling state for scheduler recomputation
    priorSchedulingState Json? @map("prior_scheduling_state")

    // Cross-service references
    traceId     String? @map("trace_id") @db.VarChar(50)
    diagnosisId String? @map("diagnosis_id") @db.VarChar(50)

    // Audit
    createdAt DateTime @default(now()) @map("created_at")

    // Relations
    session Session @relation(fields: [sessionId], references: [id])

    // Indexes
    @@index([sessionId])
    @@index([sessionId, sequenceNumber])
    @@index([userId])
    @@index([cardId])
    @@index([userId, cardId])
    @@index([createdAt])
    @@map("attempts")
}

// ============================================================================
// Session Queue Item — Dynamic card queue within a session
// ============================================================================

model SessionQueueItem {
    id        String @id @db.VarChar(50)
    sessionId String @map("session_id") @db.VarChar(50)
    cardId    String @map("card_id") @db.VarChar(50)

    lane SessionSchedulerLane @default(RETENTION)

    // Ordering
    position Int

    // Status tracking
    status CardQueueStatus @default(PENDING)

    // Injection metadata (for agent-injected cards)
    injectedBy String? @map("injected_by") @db.VarChar(100)
    reason     String? @db.VarChar(500)

    // Audit
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Relations
    session Session @relation(fields: [sessionId], references: [id])

    // Indexes
    @@unique([sessionId, cardId])
    @@index([sessionId, position])
    @@index([sessionId, status])
    @@map("session_queue_items")
}

// ============================================================================
// Session Cohort Handshake — auditable proposal/decision lineage
// ============================================================================

model SessionCohortHandshake {
    id String @id @db.VarChar(50)

    sessionId   String @map("session_id") @db.VarChar(50)
    proposalId  String @map("proposal_id") @db.VarChar(100)
    decisionId  String @map("decision_id") @db.VarChar(100)
    revision    Int
    status      SessionCohortHandshakeStatus

    candidateCardIds Json @map("candidate_card_ids")
    acceptedCardIds  Json? @map("accepted_card_ids")
    rejectedCardIds  Json? @map("rejected_card_ids")
    metadata         Json  @default("{}")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    session Session @relation(fields: [sessionId], references: [id])

    @@unique([sessionId, proposalId, revision])
    @@index([sessionId, status])
    @@index([sessionId, proposalId, revision])
    @@map("session_cohort_handshakes")
}

// ============================================================================
// Event Outbox — durable event staging for reliable publishing
// ============================================================================

model EventOutbox {
    id String @id @db.VarChar(50)

    eventType     String @map("event_type") @db.VarChar(100)
    aggregateType String @map("aggregate_type") @db.VarChar(50)
    aggregateId   String @map("aggregate_id") @db.VarChar(50)
    payload       Json
    metadata      Json

    publishedAt DateTime? @map("published_at")
    claimOwner String? @map("claim_owner") @db.VarChar(100)
    claimUntil DateTime? @map("claim_until")
    nextAttemptAt DateTime? @map("next_attempt_at")
    attempts    Int       @default(0)
    lastError   String?   @map("last_error") @db.VarChar(1000)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@index([publishedAt, createdAt])
    @@index([attempts])
    @@index([publishedAt, claimUntil, nextAttemptAt, createdAt])
    @@index([claimOwner, claimUntil])
    @@map("event_outbox")
}

// ============================================================================
// Offline Intent Token Replay Guard — durable single-use protection
// ============================================================================

model OfflineIntentTokenReplayGuard {
    jti String @id @db.VarChar(100)
    userId String @map("user_id") @db.VarChar(50)
    issuedAt DateTime @map("issued_at")
    expiresAt DateTime @map("expires_at")
    consumedAt DateTime? @map("consumed_at")
    status OfflineIntentTokenReplayGuardStatus @default(ISSUED)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@index([userId, status])
    @@index([expiresAt, status])
    @@index([consumedAt])
    @@map("offline_intent_token_replay_guard")
}

// ============================================================================
// Enums
// ============================================================================

enum SessionState {
    ACTIVE
    PAUSED
    COMPLETED
    ABANDONED
    EXPIRED

    @@map("session_state")
}

enum StudyMode {
    LANGUAGE_LEARNING
    KNOWLEDGE_GAINING
}

enum LearningMode {
    EXPLORATION
    GOAL_DRIVEN
    EXAM_ORIENTED
    SYNTHESIS

    @@map("learning_mode")
}

enum AttemptOutcome {
    CORRECT
    INCORRECT
    PARTIAL
    SKIPPED

    @@map("attempt_outcome")
}

enum Rating {
    AGAIN
    HARD
    GOOD
    EASY

    @@map("rating")
}

enum HintDepth {
    NONE
    CUE
    PARTIAL
    FULL_EXPLANATION

    @@map("hint_depth")
}

enum CardQueueStatus {
    PENDING
    PRESENTED
    COMPLETED
    SKIPPED
    INJECTED

    @@map("card_queue_status")
}

enum SessionSchedulerLane {
    RETENTION
    CALIBRATION

    @@map("session_scheduler_lane")
}

enum SessionCohortHandshakeStatus {
    PROPOSED
    ACCEPTED
    REVISED
    COMMITTED
    CANCELLED

    @@map("session_cohort_handshake_status")
}

enum OfflineIntentTokenReplayGuardStatus {
    ISSUED
    CONSUMED
    EXPIRED

    @@map("offline_intent_token_replay_guard_status")
}

// ============================================================================
// User Streak — Materialized streak cache (Phase 5, T5.4)
// ============================================================================
// One row per user. Incrementally updated when a session completes.
// Lazy-reset on read: if lastActiveDate is more than 1 day ago,
// currentStreak returns 0.

model UserStreak {
    userId         String   @map("user_id") @db.VarChar(50)
    studyMode      StudyMode @default(KNOWLEDGE_GAINING) @map("study_mode")
    currentStreak  Int      @default(0) @map("current_streak")
    longestStreak  Int      @default(0) @map("longest_streak")
    lastActiveDate DateTime @map("last_active_date") @db.Date
    timezone       String   @default("UTC") @db.VarChar(50)
    createdAt      DateTime @default(now()) @map("created_at")
    updatedAt      DateTime @updatedAt @map("updated_at")

    @@id([userId, studyMode])
    @@index([userId])
    @@map("user_streaks")
}
