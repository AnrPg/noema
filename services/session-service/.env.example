# =============================================================================
# @noema/session-service Environment Configuration
# =============================================================================

# Service
NODE_ENV=development
SERVICE_VERSION=1.0.0
HOST=0.0.0.0
PORT=3003

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/session_db

# Redis / Event Bus
REDIS_URL=redis://localhost:6379
REDIS_EVENT_STREAM=noema:events:session-service
REDIS_STREAM_MAX_LEN=10000

# Session
SESSION_TIMEOUT_HOURS=24
MAX_CONCURRENT_SESSIONS=1

# CORS (disabled by default — the API gateway handles CORS)
# Set CORS_ENABLED=true only when running without the gateway.
# CORS_ENABLED=false
# CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3004
# CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true

# Security — Offline Intent Token (session-service is the single authority per ADR-0023)
VERIFY_OFFLINE_INTENT_TOKENS=true
OFFLINE_INTENT_TOKEN_SECRET=replace-with-secure-long-random-secret-min-32-chars
# Key ring format: comma-separated kid:secret pairs (preferred over single secret)
OFFLINE_INTENT_TOKEN_KEYS=
OFFLINE_INTENT_TOKEN_ACTIVE_KID=default
OFFLINE_INTENT_TOKEN_ISSUER=noema.session
OFFLINE_INTENT_TOKEN_AUDIENCE=noema.mobile

# Auth middleware (local development)
AUTH_DISABLED=true
JWT_SECRET=dev-secret
JWT_ISSUER=noema.app
JWT_AUDIENCE=noema.app
