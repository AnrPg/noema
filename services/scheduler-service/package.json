{
  "name": "@noema/scheduler-service",
  "version": "0.1.0",
  "description": "Spaced repetition scheduler service for Noema",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "lint": "eslint --config ../../eslint.config.mjs \"src/**/*.ts\"",
    "lint:fix": "eslint --config ../../eslint.config.mjs \"src/**/*.ts\" --fix",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@noema/contracts": "workspace:*",
    "@noema/events": "workspace:*",
    "@noema/types": "workspace:*",
    "@noema/validation": "workspace:*",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "jose": "^6.0.11",
    "pino": "^9.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
