# =============================================================================
# @noema/scheduler-service Environment Configuration
# =============================================================================

# Service
NODE_ENV=development
SERVICE_NAME=scheduler-service
SERVICE_VERSION=0.1.0
HOST=0.0.0.0
PORT=3009

# Redis / Event Bus
REDIS_URL=redis://localhost:6379
REDIS_EVENT_STREAM=noema:events:scheduler-service
REDIS_STREAM_MAX_LEN=10000

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3003,http://localhost:3004
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true

# Security
OFFLINE_INTENT_TOKEN_SECRET=replace-with-secure-long-random-secret
OFFLINE_INTENT_TOKEN_ISSUER=noema.scheduler
OFFLINE_INTENT_TOKEN_AUDIENCE=noema.mobile

# Auth middleware (local development)
AUTH_DISABLED=true
JWT_SECRET=dev-secret
JWT_ISSUER=noema.app
JWT_AUDIENCE=noema.app
