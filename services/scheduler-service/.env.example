# =============================================================================
# @noema/scheduler-service Environment Configuration
# =============================================================================

# Service
NODE_ENV=development
SERVICE_NAME=scheduler-service
SERVICE_VERSION=0.1.0
HOST=0.0.0.0
PORT=3009

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/scheduler_db

# Redis / Event Bus
REDIS_URL=redis://localhost:6379
REDIS_EVENT_STREAM=noema:events:scheduler-service
REDIS_STREAM_MAX_LEN=10000
REDIS_SOURCE_STREAM=noema:events:session-service
REDIS_CONSUMER_GROUP=scheduler-service-group
REDIS_CONSUMER_NAME=scheduler-service-1
REDIS_CONSUMER_BLOCK_MS=5000
REDIS_CONSUMER_BATCH_SIZE=20

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3003,http://localhost:3004
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true

# Auth middleware (local development)
AUTH_DISABLED=true
JWT_SECRET=dev-secret
JWT_ISSUER=noema.app
JWT_AUDIENCE=noema.app
