# ============================================================================
# ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================================================

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL="postgresql://flashcard_user:flashcard_dev_password@localhost:5432/flashcard_db"

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL="redis://localhost:6379"

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Generate a secure random string (32+ characters)
# You can use: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================================================
# API SERVER
# ============================================================================
PORT=3000
NODE_ENV=development
CORS_ORIGIN="*"
MAX_FILE_SIZE=10485760  # 10MB in bytes

# ============================================================================
# MINIO / S3 STORAGE
# ============================================================================
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
MINIO_BUCKET_NAME="flashcards"
MINIO_USE_SSL=false

# ============================================================================
# QDRANT VECTOR DATABASE (for AI features)
# ============================================================================
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""  # Optional, leave empty for local dev

# ============================================================================
# AI SERVICES (Optional - for future AI features)
# ============================================================================
OPENAI_API_KEY=""  # Get from https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=""  # Get from https://console.anthropic.com/

# ============================================================================
# EXPO / REACT NATIVE (Mobile App)
# ============================================================================
EXPO_PUBLIC_API_URL="http://localhost:3000"
EXPO_PUBLIC_WS_URL="ws://localhost:3000"

# ============================================================================
# MONITORING & ANALYTICS (Optional)
# ============================================================================
SENTRY_DSN=""  # Get from https://sentry.io
SENTRY_ENVIRONMENT="development"

# ============================================================================
# EMAIL (Optional - for user notifications)
# ============================================================================
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="noreply@flashcards.app"

# ============================================================================
# NOTES:
# ============================================================================
# - Never commit .env to version control
# - Use strong, unique values in production
# - Rotate secrets regularly
# - Use environment-specific files (.env.development, .env.production)
