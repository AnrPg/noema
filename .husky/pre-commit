#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# =============================================================================
# PRE-COMMIT HOOK
# =============================================================================
# Runs before each commit to ensure code quality

echo "🔍 Running pre-commit checks..."

