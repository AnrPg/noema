#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# =============================================================================
# PRE-PUSH HOOK
# =============================================================================
# Runs before pushing to remote

echo "🚀 Running pre-push checks..."

# Run type checking
echo "📝 Running type check..."
pnpm typecheck || echo "⚠️  Type check skipped (no packages configured yet)"

# Run tests if they exist
echo "🧪 Running tests..."
pnpm test || echo "⚠️  Tests skipped (no tests configured yet)"

echo "✅ Pre-push checks completed!"
