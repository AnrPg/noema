# =============================================================================
# Noema Web Admin — Environment Configuration
# =============================================================================
# Copy this file to .env.local and adjust values for your environment.
# .env.local is gitignored and will not be committed.
# =============================================================================

# API Gateway URL — all backend requests route through Traefik
# Must match GATEWAY_PORT in the root .env (currently 8090).
# Default was 8080 but GATEWAY_PORT=8090 is set in root .env.
# To bypass the gateway and hit a service directly:
#   NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:8090/api
